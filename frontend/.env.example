# ── Backend API ───────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_URL — baked into the browser bundle at build time (used by the browser).
#   Local dev:  http://localhost:8080/api
#   Production: https://yourdomain.com/api  (set via FRONTEND_API_URL GitHub Actions variable)
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# INTERNAL_API_URL — server-side (SSR) only; injected at container start, never bundled.
#   Keeps SSR traffic on the Docker network instead of the public internet.
#   Set in docker-compose.prd.yml: http://backend-prd:8080/api
#   Leave unset locally (falls back to NEXT_PUBLIC_API_URL).
# INTERNAL_API_URL=

# ── LINE Webhook ───────────────────────────────────────────────────────────────
# Public-facing base URL shown to users as their LINE webhook URL.
# Must be reachable by LINE's servers (i.e. your public domain in production).
# Falls back to NEXT_PUBLIC_API_URL if not set.
# Example (production): https://yourdomain.com/api
NEXT_PUBLIC_LINE_WEBHOOK_BASE_URL=

# ── Agent WebSocket (optional fallback) ───────────────────────────────────────
# Direct WebSocket URL to the Python agent service (:50052).
# Used as an emergency reconnect fallback if the primary backend WS fails.
# Leave empty to disable the fallback.
NEXT_PUBLIC_AGENT_WS_URL=ws://localhost:50052

# ── Vercel (auto-injected — do not set manually) ──────────────────────────────
# VERCEL_URL is injected automatically by Vercel deployments. Do not set locally.
# VERCEL_URL=
