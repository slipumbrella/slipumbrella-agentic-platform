# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=8080

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=           # required — no default
DB_NAME=agent_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=            # required — min 32 characters
JWT_ISSUER=egco-agent-platform
JWT_AUDIENCE=egco-agent-platform

# ── Frontend / Cookies ────────────────────────────────────────────────────────
# Public deployments should use https:// for FRONTEND_URL.
FRONTEND_URL=http://localhost:3000
COOKIE_SECURE=false    # set true for public HTTPS deployments
COOKIE_DOMAIN=         # set only if you need auth cookies shared across subdomains

# ── Cloudflare R2 (file storage) ─────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
R2_ENDPOINT=           # https://<account-id>.r2.cloudflarestorage.com
R2_BUCKET=
R2_PUBLIC_BUCKET=      # bucket name for public assets (e.g. icons)
R2_PUBLIC_URL=         # public URL or custom domain (e.g. https://cdn.example.com)

# ── Typhoon OCR ───────────────────────────────────────────────────────────────
TYPHOON_API_KEY=

# ── Jina (embeddings) ─────────────────────────────────────────────────────────
JINA_API_KEY=
OPENROUTER_API_KEY=    # required for models listed in OpenRouter

# ── gRPC (Python agent service) ───────────────────────────────────────────────
GRPC_HOST=localhost     # use service name (e.g. "agent") inside Docker Compose
GRPC_PORT=9000

# ── Redis (rate limiter) ──────────────────────────────────────────────────────
REDIS_HOST=localhost    # use service name (e.g. "redis") inside Docker Compose
REDIS_PORT=6379
REDIS_PASSWORD=
