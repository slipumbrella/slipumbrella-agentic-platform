# ── LLM (OpenRouter) ──────────────────────────────────────────────────────────
CORE_MODEL=openrouter/hunter-alpha
MODEL=openrouter/hunter-alpha

# ── LLM / GLM (optional alternative) ─────────────────────────────────────────
GLM_API_KEY=

# ── gRPC server ───────────────────────────────────────────────────────────────
GRPC_HOST=0.0.0.0
GRPC_PORT=50051

# ── Fallback WebSocket server ─────────────────────────────────────────────────
WS_HOST=0.0.0.0
WS_PORT=50052

# ── Runtime environment ───────────────────────────────────────────────────────
ENVIRONMENT=debug         # debug | production

# ── Jina AI (web search & fetch tools) ────────────────────────────────────────
JINA_API_KEY=             # required for web_research / web_fetch_page tools

# ── Backend API ───────────────────────────────────────────────────────────────
BACKEND_URL=http://backend:8080   # docker-compose service name; use http://localhost:8080 for local dev

# ── OpenRouter (LLM judge for data quality evaluation) ────────────────────────
OPENROUTER_API_KEY=       # required for EvaluateRAG RPC
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
JUDGE_MODEL=minimax/minimax-01

# ── PostgreSQL / pgvector ─────────────────────────────────────────────────────
# Note: this is the pgvector instance (default port 5433), not the main DB (5432)
DB_HOST=localhost
DB_PORT=5433
DB_NAME=egco_capstone
DB_USER=postgres
DB_PASSWORD=              # required

# ── Connection pool ───────────────────────────────────────────────────────────
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Google Workspace (Service Account) ────────────────────────────────────────
# Get these values from your Service Account JSON key file
GOOGLE_SA_PROJECT_ID=
GOOGLE_SA_PRIVATE_KEY_ID=
GOOGLE_SA_PRIVATE_KEY=        # Store \n as literal \n characters
GOOGLE_SA_CLIENT_EMAIL=
GOOGLE_SA_CLIENT_ID=
