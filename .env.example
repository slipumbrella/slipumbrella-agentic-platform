# Root .env — read by docker-compose for variable substitution in docker-compose.prd.yml.
# Copy to .env and fill in production values before running `docker compose -f docker-compose.prd.yml build`.

# Redis password (shared by backend, agent, and redis services)
REDIS_PASSWORD=

# Frontend build-time vars — baked into the Next.js bundle at `docker compose build`.
NEXT_PUBLIC_API_URL=https://api.slipumbrella.com/api
NEXT_PUBLIC_AGENT_WS_URL=wss://api.slipumbrella.com:50052
NEXT_PUBLIC_LINE_WEBHOOK_BASE_URL=
